{
  "container-network": {
    "name": "spoutnetwork",
    "driver": "bridge"
  },
  "servers": [
    {
      "name": "spoutproxy",
      "image": "itzg/bungeecord",
      "ports": {
        "hostPort": "25565",
        "containerPort": "25577"
      },
      "env": {
        "TZ": "Europe/Zurich",
        "LOG_PINGS": "FALSE"
      },
      "volumes": [
        {
          "hostpath": [
            "testservers",
            "data",
            "spoutproxy"
          ],
          "containerpath": "/server"
        }
      ]
    },
    {
      "name": "spoutlobby",
      "image": "itzg/minecraft-server",
      "ports": {
        "hostPort": "25566",
        "containerPort": "25565"
      },
      "env": {
        "EULA": "TRUE",
        "TYPE": "PAPER",
        "ONLINE_MODE": "FALSE",
        "ENFORCE_SECURE_PROFILE": "FALSE",
        "MAX_MEMORY": "4G",
        "VERSION": "1.20.2",
        "GUI": "FALSE",
        "CONSOLE": "FALSE",
        "LOG_TIMESTAMP": "TRUE",
        "TZ": "Europe/Zurich"
      },
      "volumes": [
        {
          "hostpath": [
            "testservers",
            "data",
            "spoutlobby"
          ],
          "containerpath": "/data"
        }
      ]
    },
    {
      "name": "spoutskyblock",
      "image": "itzg/minecraft-server",
      "ports": {
        "hostPort": "25567",
        "containerPort": "25565"
      },
      "env": {
        "EULA": "TRUE",
        "TYPE": "SPIGOT",
        "ONLINE_MODE": "FALSE",
        "ENFORCE_SECURE_PROFILE": "FALSE",
        "MAX_MEMORY": "4G",
        "GUI": "FALSE",
        "CONSOLE": "FALSE",
        "LOG_TIMESTAMP": "TRUE",
        "TZ": "Europe/Zurich"
      },
      "volumes": [
        {
          "hostpath": [
            "testservers",
            "data",
            "spoutskyblock"
          ],
          "containerpath": "/data"
        }
      ]
    }
  ]
}