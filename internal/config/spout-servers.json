{
  "container-network": {
    "name": "spoutnetwork",
    "driver": "bridge"
  },
  "server": [
    {
      "name": "spoutproxy",
      "image": "itzg/bungeecord",
      "ports": {
        "hostPort": "25565",
        "containerPort": "25577"
      },
      "env": {
        "TYPE": "VELOCITY",
        "TZ": "Europe/Zurich"
      },
      "volumes": [
        {
          "hostpath": "/Users/florianthievent/workspace/private/spoutmc/testservers/data/proxy",
          "containerpath": "/data"
        }
      ]
    },
    {
      "name": "spoutlobby",
      "image": "itzg/minecraft-server",
      "ports": {
        "hostPort": "30066",
        "containerPort": "25565"
      },
      "env": {
        "EULA": "TRUE",
        "TYPE": "SPIGOT",
        "ONLINE_MODE": "FALSE",
        "ENFORCE_SECURE_PROFILE": "FALSE",
        "MAX_MEMORY": "4G",
        "VERSION": "1.20.2",
        "GUI": "FALSE",
        "CONSOLE": "FALSE",
        "LOG_TIMESTAMP": "TRUE",
        "TZ": "Europe/Zurich"
      }
    }
  ]
}