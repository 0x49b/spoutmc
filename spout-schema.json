{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#SpoutConfiguratioSchema",
  "title": "SpoutMC Schema",
  "description": "SpoutMC configuration schema",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Url to define a schema for the spout-configuration.json",
      "default": "https://0x49b.github.io/spoutmc/spout-schema.json"
    },
    "base": {
      "description": "Add basic behaviour",
      "type": "object",
      "properties": {
        "restart_servers": {
          "type": "boolean",
          "description": "restart all game servers when spout is starting",
          "default": true
        },
        "stop_servers": {
          "type": "boolean",
          "description": "Stop all game servers when spout is (gracefully) shutdown",
          "default": true
        }
      }
    },
    "database": {
      "description": "Configuration values for the Database",
      "type": "object",
      "properties": {
        "db_type": {
          "type": "string",
          "description": "database system",
          "default": [
            "mysql"
          ]
        },
        "db_port": {
          "type": "number",
          "description": "Database Port to connect"
        },
        "db_user": {
          "type": "string",
          "description": "User to connect"
        },
        "db_password": {
          "type": "string",
          "description": "Password to connect"
        },
        "db_name": {
          "type": "string",
          "description": "Name of Database"
        },
        "enable_phpmyadmin": {
          "type": "boolean",
          "description": "Starts an instance of PHPMyAdmin and connect it to the Database"
        },
        "external_database": {
          "type": "boolean",
          "description": "If set to true, then SpoutMC will try to connect to an external database host. If set to false, SpoutMc will start a Database Container"
        },
        "external_host": {
          "type": "string",
          "description": "Hostname for a external database host. Must be set if <external_database> is set to true"
        }
      },
      "required": [
        "db_type",
        "db_port",
        "db_user",
        "db_password",
        "db_name",
        "enable_phpmyadmin",
        "external_database"
      ]
    }
  },
  "required": [
    "database"
  ]
}
